# --- Filer : variables d'environnement ---
# Copier ce fichier en .env (non versionné) et adapter les valeurs.

# Emails ayant un accès admin complet (séparés par des virgules).
# Comparaison insensible à la casse / aux espaces.
ADMIN_EMAILS=toi@example.com,autre-admin@example.com

# Secret de signature des cookies de session (long et aléatoire).
# Générer : openssl rand -base64 48
SESSION_SECRET=remplace-moi-par-une-chaine-longue-et-aleatoire

# Taille maximale d'un upload, en Mo (défaut applicatif : 1024).
MAX_UPLOAD_MB=1024

# URL publique de l'application (utilisée pour construire les liens de partage).
APP_URL=https://filer.gautierchuinard.com
